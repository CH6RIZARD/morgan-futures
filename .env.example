# Copy to .env locally. On Railway, set these in the service Variables tab.

# --- Alerts ---
SIGNAL_EMAIL_TO=daniel4chigs@gmail.com
SIGNAL_SMS_TO=+14699542425

# --- SMTP (Gmail — use an App Password, not your normal password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=youraddress@gmail.com
SMTP_TLS=1

# --- Twilio SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1your_twilio_number

# --- Scanner ---
SIGNALS_ENABLED=1
SCAN_INTERVAL_SEC=60
SIGNAL_STALE_WINDOW_SEC=300
SIGNAL_RR_DEFAULT=1.0

# Optional: override symbols (comma-separated Yahoo tickers)
# BOT_SYMBOLS=

# =============================================================
# RITHMIC LIVE TRADING (Lucid PropFirm)
# =============================================================
# Set LIVE_TRADING_ENABLED=1 to enable live order execution.
# Leave at 0 for signals-only mode (default, safe).
LIVE_TRADING_ENABLED=0

# Credentials from Lucid dashboard
RITHMIC_USER=your_lucid_username
RITHMIC_PASSWORD=your_lucid_password
RITHMIC_SYSTEM_NAME=Rithmic Paper Trading
RITHMIC_GATEWAY_URI=wss://rituz00100.rithmic.com:443
RITHMIC_ACCOUNT_ID=your_account_id

# Set to 1 to log all raw Rithmic protobuf messages (for debugging connection issues)
RITHMIC_DEBUG=0

# =============================================================
# LUCID CHALLENGE PARAMETERS (50K Flex)
# =============================================================
CHALLENGE_MAX_DD=2000
CHALLENGE_PROFIT_TARGET=3000
# Max profit per day — keeps any single day under 50% of total (consistency rule)
CHALLENGE_DAILY_CAP_USD=1400
# Risk per trade in USD (~$200 = ~40 ticks on RTY @ $5/tick)
TRADE_RISK_DOLLARS=200
# Hard cap: never more than N trades per day regardless of P&L
MAX_TRADES_PER_DAY=5

# Starting balance (must match your Lucid account size)
PAPER_START_BALANCE=50000
