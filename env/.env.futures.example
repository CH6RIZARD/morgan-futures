# Futures-focused defaults (copy to `.env` locally; on Railway set Variables).
#
# The ranker/backtests use Yahoo intraday; if you see rate-limit errors, reduce period.
YF_INTRADAY_PERIOD=30d

# Backtest depth (futures: less required to avoid source limitations)
BACKTEST_DAYS_BACK=30
BACKTEST_MIN_CANDLES=600

# Tier thresholds (futures can be noisier; require fewer trades to show)
BASE_MIN_TRADES=10
ELITE_MIN_TRADES=8
SUPER_MIN_TRADES=12

# Symbols (Yahoo futures tickers)
BOT_SYMBOLS=ES=F,MES=F,NQ=F,MNQ=F,RTY=F,M2K=F,GC=F,MGC=F,SI=F,HG=F,CL=F,MCL=F

