# Copy to .env locally. On Railway, set these in the service Variables tab.

# --- Alerts (signals only; no broker orders) ---
SIGNAL_EMAIL_TO=daniel4chigs@gmail.com
# E.164 for Twilio
SIGNAL_SMS_TO=+14699542425

# --- SMTP (Gmail example: use an App Password, not your normal password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=youraddress@gmail.com
SMTP_TLS=1

# --- Twilio SMS (optional; omit TWILIO_* to disable SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1your_twilio_number

# --- Scanner ---
SIGNALS_ENABLED=1
SCAN_INTERVAL_SEC=60
SIGNAL_STALE_WINDOW_SEC=300
SIGNAL_RR_DEFAULT=1.0

# Optional: override symbols (comma-separated Yahoo tickers, e.g. ES=F,MNQ=F)
# BOT_SYMBOLS=
